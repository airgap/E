{
  "name": "e",
  "private": true,
  "description": "A desktop AI assistant powered by Claude",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/airgap/maude"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "main": "electron/dist/main.cjs",
  "trustedDependencies": [
    "electron",
    "electron-builder"
  ],
  "build": {
    "appId": "dev.script.e",
    "productName": "E"
  },
  "scripts": {
    "dev": "nx run-many --target=dev --parallel=3",
    "dev:server": "nx run @e/server:dev",
    "dev:client": "nx run @e/client:dev",
    "cli:dev": "bun packages/server/src/cli/main.ts",
    "build": "nx run-many --target=build",
    "build:desktop": "(cd packages/client && bun run build) && (cd packages/server && bun run build:binary) && bun run suffix-binary",
    "build:standalone": "bun run scripts/build-standalone.ts",
    "install:local": "bash scripts/install-local.sh",
    "build:golem": "cd packages/server && bun run build:golem",
    "suffix-binary": "bun run scripts/suffix-binary.ts",
    "tauri:dev": "(cd packages/server && bun run build:binary) && bun run suffix-binary && bun tauri dev",
    "tauri:build": "bun tauri build",
    "electron:shell": "bun run scripts/build-electron-shell.ts",
    "electron:dev": "(cd packages/client && bun run build) && (cd packages/server && bun run build:binary) && bun run electron:shell && electron .",
    "start": "(cd packages/client && bun run build) && (cd packages/server && bun run start)",
    "check": "nx run-many --target=check",
    "check:types": "nx run-many --target=check",
    "test": "nx run-many --target=test",
    "test:affected": "nx affected --target=test",
    "check:affected": "nx affected --target=check",
    "test:coverage": "bun run --filter @e/server test:coverage && bun run --filter @e/shared test:coverage && bun run --filter @e/client test:coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.0",
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "esbuild": "^0.24.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nx": "^22.5.2",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,js,svelte,json,css,md,html}": "prettier --write"
  },
  "dependencies": {
    "@xterm/addon-image": "0.9.0"
  }
}
